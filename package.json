{
  "name": "opensearch-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "Diagnostic web app for Amazon OpenSearch Service clusters",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @osa/api run dev",
    "dev:web": "npm --workspace @osa/web run dev",
    "build": "npm --workspaces --if-present run build",
    "test": "npm --workspaces --if-present run test",
    "lint": "npm --workspaces --if-present run lint",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
